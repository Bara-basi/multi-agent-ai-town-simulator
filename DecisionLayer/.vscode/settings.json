{
    "git.ignoreLimitWarning": true,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "comment.line",
                    "comment.block"
                ],
                "settings": {
                    "foreground": "#4EC9B0",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "punctuation.definition.comment",
                "settings": {
                    "foreground": "#4EC9B0"
                }
            }
        ]
    }
}